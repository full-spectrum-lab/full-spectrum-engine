{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/full-spectrum-lab/full-spectrum-protocol/schemas/input-envelope.schema.json",
  "title": "ObserverInputEnvelope",
  "description": "v1.2 observer input contract (SRS §3.1/§3.2). Carries business data, subject/relationship references, evidence, known facts, explicit UNKNOWN, Profile/Adapter refs, L4-compatible reference fields, and gate state. additionalProperties false enforces strict validation (NFR-05).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "layer",
    "scope",
    "subject_refs",
    "business_data",
    "gate",
    "l4_mode"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "gie-1.2" },
    "schema_version": { "type": "string", "const": "gie-1.2" },
    "contract_version": { "type": "string", "minLength": 1 },
    "layer": { "type": "string", "enum": ["L1", "L2", "L3", "L4"] },
    "scope": { "type": "string", "enum": ["internal", "external_candidate"] },
    "subject_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "relationship_refs": { "type": "array", "items": { "type": "string" } },
    "business_data": { "type": "object" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "known_facts": { "type": "object" },
    "unknowns": {
      "type": "object",
      "description": "Explicit unknown/uncertain items. Must be present (even if empty) so UNKNOWN is never silent (FR-07)."
    },
    "profile_refs": { "type": "array", "items": { "type": "string" } },
    "knowledge_source_refs": { "type": "array", "items": { "type": "string" } },
    "credential_refs": { "type": "array", "items": { "type": "string" } },
    "verification_result_refs": { "type": "array", "items": { "type": "string" } },
    "authorization_refs": { "type": "array", "items": { "type": "string" } },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_flow", "qualification", "authorization", "mutual_auth", "effective_state"],
      "properties": {
        "layer_flow": { "$ref": "#/$defs/gate_record" },
        "qualification": { "$ref": "#/$defs/gate_record" },
        "authorization": { "$ref": "#/$defs/gate_record" },
        "mutual_auth": { "$ref": "#/$defs/gate_record" },
        "effective_state": { "type": "string", "enum": ["INTERNAL_ONLY", "EXTERNAL_CANDIDATE", "EXTERNAL_ACTIVE"] }
      }
    },
    "l4_mode": { "type": "string", "enum": ["DISABLED", "LOCAL_SIMULATION", "NETWORK_CANDIDATE"] },
    "l4_refs": {
      "type": "object",
      "additionalProperties": true,
      "description": "L4-compatible reference fields (trust_domain/credential/mutual_auth/authorization/verification_result). Carried and format-checked only; never validated or used to produce external effect (first-gen only compatible, not forge)."
    },
    "context_metadata": { "type": "object" },
    "audit_metadata": { "type": "object" }
  },
  "$defs": {
    "gate_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reason_code"],
      "properties": {
        "state": { "type": "string", "enum": ["OPEN", "CLOSED", "INTERNAL_OPEN_EXTERNAL_CLOSED"] },
        "reason_code": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  }
}
