{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/full-spectrum-lab/full-spectrum-protocol/schemas/observer-output-envelope.schema.json",
  "title": "ObserverOutputEnvelope",
  "description": "v1.2 observer output contract (SRS §3.3). Pairs with input-envelope (gie-1.2). explanation/runestone/audit_ref/replay_ref are split; replay_ref is optional (full Replay deferred to v1.4). external_effect is always false in v1.2 (L4_CANDIDATE is not yet active).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "analysis_result",
    "fshi_measurement",
    "risk_vector",
    "explanation",
    "runestone",
    "audit_ref",
    "content_digest",
    "l4_mode",
    "external_effect"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "goe-1.2" },
    "schema_version": { "type": "string", "const": "goe-1.2" },
    "contract_version": { "type": "string", "minLength": 1 },
    "analysis_result": { "type": "object" },
    "fshi_measurement": { "type": "object" },
    "risk_vector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimensions", "values"],
      "properties": {
        "dimensions": { "type": "array", "items": { "type": "string" } },
        "values": { "type": "array", "items": { "type": "number" } },
        "note": { "type": "string" },
        "profile_driven": { "type": "boolean", "description": "v1.3: true when computed from Profiles (vs v1.2 stub)" },
        "computation": { "type": "string", "description": "v1.3 computation identifier, e.g. profile_driven_v1.3" },
        "source_profile_versions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "v1.3: id@version list of source profiles; enables v1.4 replay"
        },
        "deterministic": { "type": "boolean", "description": "v1.3: true when output is reproducible from (business_data, profile versions)" }
      }
    },
    "ess_candidates": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "human_review_recommendation": { "type": "object" },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "basis": { "type": "array", "items": { "type": "string" } }
      }
    },
    "runestone": { "type": "object" },
    "audit_ref": { "type": "string", "minLength": 1 },
    "replay_ref": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["event_id", "event_digest", "bundle_ref"],
      "properties": {
        "event_id": { "type": "string", "pattern": "^evt_[0-9a-f]{16}$" },
        "event_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bundle_ref": { "type": "string", "pattern": "^bundle_[0-9a-f]{16}$" }
      },
      "description": "v1.4: real, resolvable reference to the recording EvaluationEvent. null when calling run_envelope directly (v1.2/v1.3 path). Forgery (non-null with unresolvable event_id) is a red-line violation detected by IntegrityChecker."
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_flow", "qualification", "authorization", "mutual_auth", "effective_state"],
      "properties": {
        "layer_flow": { "$ref": "#/$defs/gate_record" },
        "qualification": { "$ref": "#/$defs/gate_record" },
        "authorization": { "$ref": "#/$defs/gate_record" },
        "mutual_auth": { "$ref": "#/$defs/gate_record" },
        "effective_state": { "type": "string", "enum": ["INTERNAL_ONLY", "EXTERNAL_CANDIDATE", "EXTERNAL_ACTIVE"] }
      }
    },
    "l4_mode": { "type": "string", "enum": ["DISABLED", "LOCAL_SIMULATION", "NETWORK_CANDIDATE"] },
    "external_effect": { "type": "boolean", "const": false },
    "content_digest": { "type": "string", "minLength": 1 },
    "unknown_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flag"],
        "properties": {
          "flag": { "type": "string" },
          "detail": {}
        }
      },
      "description": "v1.3: explicit UNKNOWN items (from env.unknowns); never silent (FR-06)"
    },
    "hard_forbidden": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "condition_id"],
        "properties": {
          "scenario_id": { "type": "string" },
          "scenario_type": { "type": "string" },
          "condition_id": { "type": "string" },
          "description": { "type": "string" },
          "field": { "type": "string" }
        }
      },
      "description": "v1.3: triggered hard-forbidden conditions; explicitly flagged, not masked by aggregate (FR-06)"
    },
    "scenario_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "v1.3: scenario profiles referenced by this evaluation"
    },
    "eligibility_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibility_candidate", "requirements_satisfied", "external_auth_required", "trust_domain_results"],
      "properties": {
        "eligibility_candidate": { "type": "string", "enum": ["CANDIDATE", "NOT_CANDIDATE", "UNKNOWN"] },
        "requirements_satisfied": { "type": "boolean" },
        "external_auth_required": { "type": "boolean" },
        "trust_domain_results": {
          "type": "object",
          "additionalProperties": { "type": "boolean" },
          "description": "v1.3: per trust-domain satisfaction; NEVER merged into a single boolean"
        },
        "note": { "type": "string" }
      },
      "description": "v1.3: local eligibility CANDIDATE state only; never a certification/authorization conclusion"
    }
  },
  "$defs": {
    "gate_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reason_code"],
      "properties": {
        "state": { "type": "string", "enum": ["OPEN", "CLOSED", "INTERNAL_OPEN_EXTERNAL_CLOSED"] },
        "reason_code": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  }
}
