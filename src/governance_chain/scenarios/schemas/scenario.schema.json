{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/full-spectrum-lab/full-spectrum-protocol/schemas/scenario.schema.json",
  "title": "ScenarioProfile",
  "description": "v1.3 Scenario Profile（治理场景，与 Adapter 分离）。scenario_type 枚举三类：Overcommitment / CustomerServiceAudit / KnowledgeConflict。顶层 additionalProperties:false（反模式红线）。Scenario 仅声明治理场景（含 hard_forbidden_conditions），不携带规则引擎；规则在 Policy/Scenario，Adapter 不复制规则（AC-03）。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "schema_version",
    "scenario_type",
    "scope",
    "owner",
    "approved_by",
    "approval_status",
    "effective_from",
    "effective_until",
    "supersedes",
    "change_reason",
    "digest",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "minLength": 1 },
    "scenario_type": {
      "type": "string",
      "enum": ["Overcommitment", "CustomerServiceAudit", "KnowledgeConflict"]
    },
    "scope": {
      "type": "string",
      "enum": ["internal", "external_candidate", "enterprise"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "approved_by": { "type": "string", "minLength": 1 },
    "approval_status": {
      "type": "string",
      "enum": ["draft", "approved", "deprecated"]
    },
    "effective_from": { "type": "string", "minLength": 1 },
    "effective_until": { "type": "string", "minLength": 1 },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "change_reason": { "type": "string" },
    "digest": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "retired"]
    },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "triggers": {
          "type": "array",
          "items": { "type": "object" }
        },
        "hard_forbidden_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "description", "field", "op"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "field": { "type": "string", "minLength": 1, "description": "dot-path into the Input Envelope, e.g. business_data.refund_authority" },
              "op": {
                "type": "string",
                "enum": ["equals", "not_equals", "is_true", "is_false", "present", "absent"]
              },
              "value": {}
            }
          }
        }
      }
    }
  }
}
